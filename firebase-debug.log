[debug] [2026-05-17T19:35:36.494Z] <<< [apiv2][body] POST https://firebaserules.googleapis.com/v1/projects/trendaryo-automation-prod/rulesets {"name":"projects/trendaryo-automation-prod/rulesets/33c76b51-c6d3-4538-9bf3-d0feb82a3c42","source":{"files":[{"content":"rules_version = '2';\r\nservice cloud.firestore {\r\n  match /databases/{database}/documents {\r\n    // Helper function to check if user is authenticated\r\n    function isAuthenticated() {\r\n      return request.auth != null;\r\n    }\r\n\r\n    // Helper function to check if user is owner\r\n    function isOwner(userId) {\r\n      return isAuthenticated() && request.auth.uid == userId;\r\n    }\r\n\r\n    // Helper function to check if user has pro plan\r\n    function isProUser() {\r\n      return isAuthenticated() && get(/databases/$(database)/documents/dropease_users/$(request.auth.uid)).data.plan == 'pro';\r\n    }\r\n\r\n    // ============================================================================\r\n    // USERS COLLECTION\r\n    // ============================================================================\r\n    match /dropease_users/{userId} {\r\n      // Users can read their own data\r\n      allow read: if isOwner(userId);\r\n      // Users can update their own data (except plan)\r\n      allow update: if isOwner(userId) && !request.resource.data.diff(resource.data).affectedKeys().hasAny(['plan']);\r\n      // Only system can create users\r\n      allow create: if false;\r\n      // Only system can delete users\r\n      allow delete: if false;\r\n    }\r\n\r\n    // ============================================================================\r\n    // PRODUCTS COLLECTION\r\n    // ============================================================================\r\n    match /dropease_products/{productId} {\r\n      // Authenticated users can read products\r\n      allow read: if isAuthenticated();\r\n      // Pro users can create products\r\n      allow create: if isProUser();\r\n      // Pro users can update their own products\r\n      allow update: if isProUser();\r\n      // Pro users can delete their own products\r\n      allow delete: if isProUser();\r\n    }\r\n\r\n    // ============================================================================\r\n    // SUPPLIERS COLLECTION\r\n    // ============================================================================\r\n    match /dropease_suppliers/{supplierId} {\r\n      // Authenticated users can read suppliers\r\n      allow read: if isAuthenticated();\r\n      // Pro users can create suppliers\r\n      allow create: if isProUser();\r\n      // Pro users can update suppliers\r\n      allow update: if isProUser();\r\n      // Pro users can delete suppliers\r\n      allow delete: if isProUser();\r\n    }\r\n\r\n    // ============================================================================\r\n    // ORDERS COLLECTION\r\n    // ============================================================================\r\n    match /dropease_orders/{orderId} {\r\n      // Authenticated users can read orders\r\n      allow read: if isAuthenticated();\r\n      // Pro users can create orders\r\n      allow create: if isProUser();\r\n      // Pro users can update orders\r\n      allow update: if isProUser();\r\n      // Pro users can delete orders\r\n      allow delete: if isProUser();\r\n    }\r\n\r\n    // ============================================================================\r\n    // AUTOMATION RULES COLLECTION\r\n    // ============================================================================\r\n    match /dropease_automation_rules/{ruleId} {\r\n      // Authenticated users can read automation rules\r\n      allow read: if isAuthenticated();\r\n      // Pro users can create automation rules\r\n      allow create: if isProUser();\r\n      // Pro users can update their own automation rules\r\n      allow update: if isProUser();\r\n      // Pro users can delete their own automation rules\r\n      allow delete: if isProUser();\r\n    }\r\n\r\n    // ============================================================================\r\n    // DEFAULT DENY\r\n    // ============================================================================\r\n    match /{document=**} {\r\n      allow read, write: if false;\r\n    }\r\n  }\r\n}\r\n","name":"firebase/firestore.rules.prod"}]},"createTime":"2026-05-17T19:35:36.599503Z","metadata":{"services":["cloud.firestore"]}}
