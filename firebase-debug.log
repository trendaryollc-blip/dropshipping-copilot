[debug] [2026-05-19T11:38:42.147Z] <<< [apiv2][body] POST https://firebaserules.googleapis.com/v1/projects/trendaryo-automation-staging/rulesets {"name":"projects/trendaryo-automation-staging/rulesets/33459a79-79ee-4279-8569-74007223abae","source":{"files":[{"content":"rules_version = '2';\nservice cloud.firestore {\n  match /databases/{database}/documents {\n    // ─── Helpers ──────────────────────────────────────────────────────────────\n\n    function isSignedIn() {\n      return request.auth != null;\n    }\n\n    function isOwner(uid) {\n      return isSignedIn() && request.auth.uid == uid;\n    }\n\n    // ─── dropease_users ───────────────────────────────────────────────────────\n    // Users own their own doc.  New users are created by an admin callable or\n    // the client directly after sign-up — allow the uid match to create the\n    // first version of their own doc.\n    match /dropease_users/{userId} {\n      allow read:  if isOwner(userId);\n      allow write: if isOwner(userId);\n    }\n\n    // ─── dropease_products ────────────────────────────────────────────────────\n    // Any signed-in user can CRUD their own records.\n    // Toggle `allow write` to `if isOwner(resource.data.ownerId)` for multi-tenant.\n    match /dropease_products/{productId} {\n      allow read:  if isSignedIn();\n      allow write: if isSignedIn();\n    }\n\n    // ─── dropease_suppliers ───────────────────────────────────────────────────\n    match /dropease_suppliers/{supplierId} {\n      allow read:  if isSignedIn();\n      allow write: if isSignedIn();\n    }\n\n    // ─── dropease_orders ──────────────────────────────────────────────────────\n    match /dropease_orders/{orderId} {\n      allow read:  if isSignedIn();\n      allow write: if isSignedIn();\n    }\n\n    // ─── dropease_automation_rules ─────────────────────────────────────────────\n    match /dropease_automation_rules/{ruleId} {\n      allow read:  if isSignedIn();\n      allow write: if isSignedIn();\n    }\n\n    // ─── dropease_notifications ────────────────────────────────────────────────\n    match /dropease_notifications/{notifId} {\n      allow read:  if isOwner(resource.data.uid);\n      allow write: if isSignedIn();\n    }\n\n    // ─── dropease_analytics ───────────────────────────────────────────────────\n    match /dropease_analytics/{analyticsId} {\n      allow read:  if isSignedIn();\n      allow write: if isSignedIn();\n    }\n\n    // ─── Default deny ─────────────────────────────────────────────────────────\n    match /{document=**} {\n      allow read, write: if false;\n    }\n  }\n}\n","name":"firebase/firestore.rules.prod"}]},"createTime":"2026-05-19T11:38:42.766335Z","metadata":{"services":["cloud.firestore"]}}
