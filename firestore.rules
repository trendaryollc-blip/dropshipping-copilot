rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return isAuthenticated() && request.auth.uid == uid;
    }

    function isValidString(val, maxLen) {
      return val is string && val.size() > 0 && val.size() <= maxLen;
    }

    function isValidNumber(val) {
      return val is number;
    }

    function isValidArray(val) {
      return val is list;
    }

    // Users can read/write their own document only
    match /users/{uid} {
      allow read: if isOwner(uid);
      allow write: if isOwner(uid);
    }

    // API keys — owner only, fields are non-sensitive server-side
    match /api_keys/{uid} {
      allow read: if isOwner(uid);
      allow write: if isOwner(uid);
    }

    // Automations — owner can read/write all their runs
    match /automations/{docId} {
      allow read: if isOwner(resource.data.userId);
      allow create: if isAuthenticated()
        && request.resource.data.userId == request.auth.uid
        && isValidString(request.resource.data.moduleId, 50);
      allow delete: if isOwner(resource.data.userId);
    }

    // Products — owner only
    match /products/{docId} {
      allow read: if isOwner(resource.data.userId);
      allow create: if isAuthenticated()
        && request.resource.data.userId == request.auth.uid
        && isValidString(request.resource.data.name, 300)
        && (request.resource.data.score == null || isValidNumber(request.resource.data.score));
      allow update: if isOwner(resource.data.userId)
        // Prevent escalating ownership
        && resource.data.userId == request.resource.data.userId;
      allow delete: if isOwner(resource.data.userId);
    }

    // Suppliers — owner only
    match /suppliers/{docId} {
      allow read: if isOwner(resource.data.userId);
      allow write: if isOwner(resource.data.userId);
    }

    // Orders — owner only
    match /orders/{docId} {
      allow read: if isOwner(resource.data.userId);
      allow write: if isOwner(resource.data.userId);
    }

    // Settings — owner only
    match /settings/{uid} {
      allow read: if isOwner(uid);
      allow write: if isOwner(uid);
    }
  }
}