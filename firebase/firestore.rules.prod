rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ─── Helpers ──────────────────────────────────────────────────────────────

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isOwnerOrAdmin(userId) {
      return isOwner(userId) || get(/databases/$(database)/documents/dropease_users/$(request.auth.uid)).data.role == 'admin';
    }

    // Basic validation helpers
    function isValidString(val) {
      return val is string && val.size() > 0 && val.size() < 1000;
    }
    
    function isValidNumber(val) {
      return val is number && val >= 0;
    }

    // ─── dropease_users ───────────────────────────────────────────────────────
    match /dropease_users/{userId} {
      allow read: if isOwner(userId) || isOwnerOrAdmin(userId);
      allow create: if isOwner(userId) && request.resource.data.keys().hasAll(['name', 'email']);
      allow update: if isOwner(userId) || isOwnerOrAdmin(userId);
      allow delete: if isOwnerOrAdmin(userId); // Only admins can delete users
    }

    // ─── dropease_products ────────────────────────────────────────────────────
    match /dropease_products/{productId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && request.resource.data.keys().hasAll(['name', 'ownerId']) && request.resource.data.ownerId == request.auth.uid;
      allow update: if isSignedIn() && resource.data.ownerId == request.auth.uid;
      allow delete: if isSignedIn() && resource.data.ownerId == request.auth.uid;
    }

    // ─── dropease_suppliers ───────────────────────────────────────────────────
    match /dropease_suppliers/{supplierId} {
      allow read: if isSignedIn();
      // Suppliers are typically managed by admins or specific logic
      allow write: if isSignedIn(); 
    }

    // ─── dropease_orders ──────────────────────────────────────────────────────
    match /dropease_orders/{orderId} {
      allow read: if isSignedIn() && resource.data.ownerId == request.auth.uid;
      allow create: if isSignedIn() && request.resource.data.keys().hasAll(['ownerId', 'items', 'total']) && request.resource.data.ownerId == request.auth.uid;
      allow update: if isSignedIn() && resource.data.ownerId == request.auth.uid;
      allow delete: if isSignedIn() && resource.data.ownerId == request.auth.uid;
    }

    // ─── dropease_automation_rules ─────────────────────────────────────────────
    match /dropease_automation_rules/{ruleId} {
      allow read: if isSignedIn() && resource.data.ownerId == request.auth.uid;
      allow create: if isSignedIn() && request.resource.data.keys().hasAll(['ownerId', 'name', 'type']) && request.resource.data.ownerId == request.auth.uid;
      allow update: if isSignedIn() && resource.data.ownerId == request.auth.uid;
      allow delete: if isSignedIn() && resource.data.ownerId == request.auth.uid;
    }

    // ─── dropease_notifications ────────────────────────────────────────────────
    match /dropease_notifications/{notifId} {
      allow read: if isSignedIn() && resource.data.uid == request.auth.uid;
      allow create: if isSignedIn() && request.resource.data.uid == request.auth.uid;
      allow update: if isSignedIn() && resource.data.uid == request.auth.uid;
      allow delete: if isSignedIn() && resource.data.uid == request.auth.uid;
    }

    // ─── dropease_analytics ───────────────────────────────────────────────────
    match /dropease_analytics/{analyticsId} {
      allow read: if isSignedIn() && resource.data.ownerId == request.auth.uid;
      allow write: if isSignedIn() && resource.data.ownerId == request.auth.uid;
    }

    // ─── Default deny ─────────────────────────────────────────────────────────
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
