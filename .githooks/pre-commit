#!/bin/sh
# Prevent accidental commits of .env files (shared hooks)
STAGED_FILES=$(git diff --cached --name-only --diff-filter=ACM)
for file in $STAGED_FILES; do
  case "$file" in
    .env|.env.*|dropease/.env|dropease/.env.*)
      echo "ERROR: Attempt to commit an .env file ($file). Remove it from the commit and try again." 1>&2
      exit 1
      ;;
  esac
done
exit 0
