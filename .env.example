# ── AI Platform API Keys ──
# Each key powers ONE AI task to maximize free tier quotas
# ⚠ SET THESE IN VERCEL ENVIRONMENT VARIABLES — never commit live keys to git

# Cloudflare Workers AI - security-optimized
# Task: Fraud Detection | Free tier: 10k req/day
CLOUDFLARE_AI_API_KEY=your_cloudflare_ai_api_key_here
CLOUDFLARE_ACCOUNT_ID=your_cloudflare_account_id_here

# Groq - fastest inference for structured data
# Tasks: Order Processing, Dynamic Pricing fallback | Free tier: 30 req/min
GROQ_API_KEY=your_groq_api_key_here

# DeepSeek - strong structured analysis
# Tasks: SEO Optimization, Competitor Analysis | Free tier: ¥5M token free quota
DEEPSEEK_API_KEY=your_deepseek_api_key_here

# OpenRouter - access to multiple pricing/reasoning models
# Task: Dynamic Pricing | Free tier: $1 free credit
OPENROUTER_API_KEY=your_openrouter_api_key_here

# Mistral AI - Pixtral vision capabilities
# Task: Image Analysis | Free tier: 500k tokens free
MISTRAL_API_KEY=your_mistral_api_key_here

# Google AI (Gemini) - fallback + creative text generation
# Tasks: Product Descriptions (primary), Fallback for any failed provider | Free tier: 60 req/min
GOOGLE_AI_API_KEY=your_google_ai_api_key_here

# SerpAPI - search engine results API
# Task: Returns Review (gather return policy data) | Free tier: 100 searches/month
SERPAPI_API_KEY=your_serpapi_api_key_here

# ── Web Scraping & Data Collection ──

# ScraperAPI (Product Hunting & Competitor Analysis)
# Free tier: 5000 API credits/month
SCRAPER_API_KEY=your_scraper_api_key_here

# Apify (Advanced Web Scraping & Automation)
# Free tier: 49 compute units/month
APIFY_TOKEN=your_apify_token_here

# Scrape.do (Proxy-based Web Scraping)
# Free tier: 1000 requests/month
SCRAPE_DO_TOKEN=your_scrape_do_token_here

# ── Dropshipping Platform API Keys ──

# CJ Dropshipping - product sourcing & auto fulfillment
CJ_API_KEY=your_cj_api_key_here

# AliExpress (via Alibaba API Gateway) - product research, pricing, reviews
ALIEXPRESS_APP_KEY=your_aliexpress_app_key_here
ALIEXPRESS_APP_SECRET=your_aliexpress_app_secret_here
ALIEXPRESS_CALLBACK_URL=https://your-vercel-domain.vercel.app/ali-express-callback

# ── Zendrop (US-Based Dropshipping & Fast Shipping) ──
# Sign up: https://www.zendrop.com/
ZENDROP_API_KEY=your_zendrop_api_key_here

# ── Spocket (US/EU Suppliers & Branded Invoicing) ──
# Sign up: https://www.spocket.co/
SPOCKET_API_KEY=your_spocket_api_key_here

# ── Modalyst (Independent Brands Marketplace) ──
# Sign up: https://www.modalyst.co/
MODALYST_API_KEY=your_modalyst_api_key_here

# ── Printful (Print-on-Demand & Custom Products) ──
# Sign up: https://www.printful.com/
PRINTFUL_API_KEY=your_printful_api_key_here

# ── Email (Resend) ──
RESEND_API_KEY=your_resend_api_key_here
EMAIL_FROM=DropEase <notifications@dropease.com>

# ── Payment Processing (Stripe) ──
# ⚠ Use LIVE keys (sk_live_ / pk_live_) in production, TEST keys (sk_test_ / pk_test_) for dev
STRIPE_SECRET_KEY=your_stripe_secret_key_here
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=your_stripe_publishable_key_here
STRIPE_WEBHOOK_SECRET=your_stripe_webhook_secret_here

# ── SMS (Twilio) ──
TWILIO_ACCOUNT_SID=your_twilio_account_sid_here
TWILIO_AUTH_TOKEN=your_twilio_auth_token_here
TWILIO_FROM_NUMBER=your_twilio_from_number_here

# ── Monitoring (Sentry) ──
NEXT_PUBLIC_SENTRY_DSN=your_sentry_dsn_here

# ── Cron Jobs (shared secret for Vercel cron authentication) ──
CRON_SECRET=dc-secret-v1-a3f8c2e9b17d4

# ── Application ──
NEXT_PUBLIC_APP_URL=https://dropshipping-copilot-opal.vercel.app
NEXT_PUBLIC_SITE_URL=https://dropshipping-copilot-opal.vercel.app

# ── Trendaryo Integration ──
TRENDARYO_BASE_URL=https://trendaryo.com
TRENDARYO_API_URL=https://api.trendaryo.com
TRENDARYO_API_KEY=your_trendaryo_api_key_here

# ── Firebase Service Account (Server-side Auth) ──
# ⚠ DO NOT put this in .env — set FIREBASE_SERVICE_ACCOUNT_KEY in Vercel only
# The service account JSON is stored in secrets/service-account.json (gitignored)

# ── Firebase (client SDK) ──
NEXT_PUBLIC_FIREBASE_API_KEY=your_firebase_api_key
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your_project_id
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your_project.firebasestorage.app
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
NEXT_PUBLIC_FIREBASE_APP_ID=your_app_id
NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID=your_measurement_id