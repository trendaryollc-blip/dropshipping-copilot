{
  "framework": "nextjs",
  "crons": [
    {
      "path": "/api/cron/sync-prices",
      "schedule": "0 */2 * * *"
    },
    {
      "path": "/api/cron/check-low-stock",
      "schedule": "0 */6 * * *"
    },
    {
      "path": "/api/cron/check-automation-rules",
      "schedule": "*/30 * * * *"
    }
  ],
  "env": {
    "CRON_SECRET": "@cron-secret"
  }
}