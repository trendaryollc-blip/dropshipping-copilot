rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ─── Helpers ──────────────────────────────────────────────────────────────

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    // ─── dropease_users ───────────────────────────────────────────────────────
    // Users own their own doc.  New users are created by an admin callable or
    // the client directly after sign-up — allow the uid match to create the
    // first version of their own doc.
    match /dropease_users/{userId} {
      allow read:  if isOwner(userId);
      allow write: if isOwner(userId);
    }

    // ─── dropease_products ────────────────────────────────────────────────────
    // Any signed-in user can CRUD their own records.
    // Toggle `allow write` to `if isOwner(resource.data.ownerId)` for multi-tenant.
    match /dropease_products/{productId} {
      allow read:  if isSignedIn();
      allow write: if isSignedIn();
    }

    // ─── dropease_suppliers ───────────────────────────────────────────────────
    match /dropease_suppliers/{supplierId} {
      allow read:  if isSignedIn();
      allow write: if isSignedIn();
    }

    // ─── dropease_orders ──────────────────────────────────────────────────────
    match /dropease_orders/{orderId} {
      allow read:  if isSignedIn();
      allow write: if isSignedIn();
    }

    // ─── dropease_automation_rules ─────────────────────────────────────────────
    match /dropease_automation_rules/{ruleId} {
      allow read:  if isSignedIn();
      allow write: if isSignedIn();
    }

    // ─── dropease_notifications ────────────────────────────────────────────────
    match /dropease_notifications/{notifId} {
      allow read:  if isOwner(resource.data.uid);
      allow write: if isSignedIn();
    }

    // ─── dropease_analytics ───────────────────────────────────────────────────
    match /dropease_analytics/{analyticsId} {
      allow read:  if isSignedIn();
      allow write: if isSignedIn();
    }

    // ─── Default deny ─────────────────────────────────────────────────────────
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
